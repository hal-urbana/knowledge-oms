# Environment Configuration Template
# Copy to .env and fill in your credentials

# =============================================================================
# ARCGIS ENTERPRISE / KNOWLEDGE SERVER
# =============================================================================
ARCGIS_PORTAL_URL=https://your-portal.arcgis.com
ARCGIS_USERNAME=your-portal-username
ARCGIS_PASSWORD=your-portal-password
ARCGIS_VERIFY_SSL=true

# =============================================================================
# KNOWLEDGE GRAPH
# =============================================================================
KNOWLEDGE_GRAPH_ID=your-knowledge-graph-id
KNOWLEDGE_GRAPH_NAME=Knowledge OMS

# =============================================================================
# UNIFIED DATA LIBRARY (UDL) - KAFKA MESSAGE BROKER
# =============================================================================
UDL_BOOTSTRAP_SERVERS=broker1.udl.example.com:9092,broker2.udl.example.com:9092
UDL_TOPIC=udl.primary-topic
UDL_CONSUMER_GROUP=knowledge-oms-consumer
UDL_USERNAME=your-udl-username
UDL_PASSWORD=your-udl-password
UDL_SECURITY_PROTOCOL=SASL_SSL
UDL_SASL_MECHANISM=PLAIN

# =============================================================================
# LIGHTRAG INDEXER
# =============================================================================
LIGHTRAG_PERSIST_DIR=./lightrag_data
LIGHTRAG_EMBEDDING_MODEL=text-embedding-ada-002
LIGHTRAG_EMBEDDING_DIM=1536
LIGHTRAG_MAX_TOKEN_SIZE=8192

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
LOG_LEVEL=INFO
BATCH_SIZE=20
MAX_RETRIES=3
